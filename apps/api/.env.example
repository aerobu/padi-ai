# PADI.AI API Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.

# == App Settings ==
APP_NAME=PADI.AI API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# == Database ==
DATABASE_URL=postgresql://padi:CHANGE_ME@localhost:5432/padi
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# == Redis ==
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MIN=2
REDIS_POOL_MAX=10

# == Auth0 ==
AUTH0_SECRET=CHANGE_ME_32_BYTE_RANDOM_SECRET
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://YOUR_AUTH0_DOMAIN.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_AUDIENCE=

# == LLM Routing (COPPA-compliant) ==
# STUDENT-facing routes MUST use local Ollama models — never override with cloud LLMs
LLM_ROUTING__TUTOR=ollama/qwen2.5:72b
LLM_ROUTING__ASSESSMENT=ollama/qwen2.5:32b
LLM_ROUTING__QUESTION_GEN=anthropic/claude-3-5-sonnet-20241022
LLM_ROUTING__ADMIN=anthropic/claude-3-5-sonnet-20241022

# == Cloud LLM APIs ==
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# == Encryption ==
# REQUIRED. Must be ≥32 chars. No default in code — app will fail to start without it.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ENCRYPTION_KEY_PASSPHRASE=REPLACE_WITH_32_PLUS_CHARACTER_PASSPHRASE_FROM_SECRETS_MANAGER

# == AWS ==
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_S3_BUCKET=your-s3-bucket-name

# == Stripe (MMP stage) ==
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# == API Configuration ==
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# == Ollama ==
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:72b
OLLAMA_TUTOR_MODEL=qwen2.5:72b
OLLAMA_ASSESSMENT_MODEL=qwen2.5:32b

# == Knowledge Tracing ==
BKT_GUESS_PROB=0.1
BKT_SLIP_PROB=0.1
BKT_LEARNING_RATE=0.1

# == Logging ==
LOG_LEVEL=INFO
LOG_FORMAT=json
