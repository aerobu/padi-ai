# === Auth0 (COPPA-Compliant Authentication) ===
AUTH0_SECRET=          # 32-byte base64-encoded secret for cookie encryption
AUTH0_BASE_URL=http://localhost:3000  # For development; update for production
AUTH0_ISSUER_BASE_URL= # Auth0 tenant URL: https://your-tenant.us.auth0.com
AUTH0_CLIENT_ID=       # Auth0 application ID
AUTH0_CLIENT_SECRET=   # Auth0 application secret

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://user:password@localhost:5432/mathpath_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# === Cache (Redis) ===
REDIS_URL=redis://localhost:6379

# === LLM Configuration (LiteLLM Abstraction) ===
# Local LLMs (Ollama) — student-facing inference (COPPA-safe)
LLM_ROUTING__tutor=ollama/qwen2.5:72b
LLM_ROUTING__assessment=ollama/qwen2.5:32b

# Cloud LLMs — admin/question generation only (no student PII)
ANTHROPIC_API_KEY=      # Claude API key (for question generation)
OPENAI_API_KEY=         # OpenAI API key (for question generation / fallback)
LLM_ROUTING__question_gen=anthropic/claude-sonnet-4-6
LLM_ROUTING__admin=anthropic/claude-sonnet-4-6

# === AWS Services ===
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=      # Scoped IAM credentials (dev account only)
AWS_SECRET_ACCESS_KEY=  # See: https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-envvars.html
AWS_S3_BUCKET=mathpath-oregon-dev-media

# === AWS SES (Email) ===
AWS_SES_REGION=us-west-2
AWS_SES_FROM_EMAIL=noreply@mathpath.local

# === Stripe (MMP / Payment Processing) ===
STRIPE_SECRET_KEY=      # Stripe secret key (test key in dev)
STRIPE_PUBLISHABLE_KEY= # Stripe public key (test key in dev)
STRIPE_WEBHOOK_SECRET=  # Stripe webhook signing secret

# === PostHog (Analytics — COPPA-Compliant) ===
NEXT_PUBLIC_POSTHOG_KEY=       # PostHog project API key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
POSTHOG_PERSONAL_API_KEY=      # For server-side event tracking

# === Sentry (Error Tracking) ===
NEXT_PUBLIC_SENTRY_DSN=        # Sentry project DSN
SENTRY_AUTH_TOKEN=             # For sourcemap uploads

# === Feature Flags (Unleash) ===
UNLEASH_API_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=default:development.unleash-insecure-frontend-api-token
UNLEASH_APP_NAME=mathpath-oregon
UNLEASH_ENVIRONMENT=development

# === Development / Debug Flags ===
NODE_ENV=development
LOG_LEVEL=debug
DEBUG=mathpath:*

# === Frontend Public Config ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_VERSION=0.0.1-dev
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_POSTHOG_DISABLED=false  # Set to true to disable analytics locally

# === Vercel Environment Variables (Auto-populated by `vercel env pull`) ===
# Do NOT manually edit these — they are managed via Vercel dashboard
# See: https://vercel.com/docs/environment-variables
# VERCEL_ENV=production|preview|development (auto-set)
# VERCEL_GIT_COMMIT_SHA=... (auto-set)
# VERCEL_OIDC_TOKEN=... (pulled by `vercel env pull`, valid for ~12h)
